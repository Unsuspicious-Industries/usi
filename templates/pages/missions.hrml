<?data from="data/missions.json" as="missions"?>

<?style?>
.missions-page {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 5rem);
    padding-top: 5rem;
}
.missions-page .missions-board {
    flex: 1;
}
body > footer {
    display: none;
}
<?/style?>

<div class="missions-page">
    <?use id="missions-panel"?>
        <?bind var="missions" from="$missions"/?>
        <?variant?>wide<?/variant?>
    </?use?>
</div>
