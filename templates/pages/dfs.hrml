        <?use id="section-header"?>
            <?label?>Research Focus<?/label?>
            <?title?>What the lab works on<?/title?>
            <?subtitle?>Some of our areas of interest.<?/subtitle?>
        </?use?>
        <?use id="card-grid"?>
            <?block slot="content"?>
                <?use id="card-cmp"?>
                    <?glyph?>⊢<?/glyph?>
                    <?title?>Constrained generation<?/title?>
                    <?text?>We are buiding not only an engine but also a genealized theory of completability in context dependent languages. At the frontier between abstract semantics and concrete applications. <?/text?>
                </?use?>
                <?use id="card-cmp"?>
                    <?glyph?>λ<?/glyph?>
                    <?title?>Proofs and Programs<?/title?>
                    <?text?>Applying computer science techniques to logical reasoning, trying to discover the computational basis of intelligence. <?/text?>
                </?use?>
                <?use id="card-cmp"?>
                    <?glyph?>↓<?/glyph?>
                    <?title?>Physical formalisms<?/title?>
                    <?text?>Implementing physical dimensional analysis inside rust's type system with the <a href="https://crates.io/crates/slut" target="_blank" rel="noopener">SLUT crate</a>. Used in simulations and scientific computing.<?/text?>
                </?use?>
                <?use id="card-cmp"?>
                    <?glyph?>⊨<?/glyph?>
                    <?title?>Meta-typed grammars<?/title?>
                    <?text?>Making the meta-est theory of typed grammars.<?/text?>
                </?use?>
                <?use id="card-cmp"?>
                    <?glyph?>∂<?/glyph?>
                    <?title?>Regex derivatives<?/title?>
                    <?text?>Brzozowski derivatives for prefix validation: decide in one step whether a partial string can still complete to a match.<?/text?>
                </?use?>
                <?use id="card-cmp"?>
                    <?glyph?>≡<?/glyph?>
                    <?title?>Interaction Nets and Computation graphs<?/title?>
                    <?text?>Developpping a compute substrate for ML that uses parralelizable interaction nets.<?/text?>
                </?use?>
            </?block?>
        </?use?>
    </?block?>
</?use?>

