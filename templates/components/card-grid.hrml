<?component id="card-grid"?>
<?bind var="cols" default="3"/?>
<?style?>
.grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
}
.grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
}
.blog-grid {
    align-items: stretch;
}
@media (max-width: 768px) {
    .grid-3,
    .grid-2 {
        grid-template-columns: 1fr;
    }
}
<?/style?>
<div class="grid-$cols">
    <?slot id="content"?>
</div>
<?/component?>
